{
  "name": "zendesk-bridge-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"node server.js\" \"cd client && npx vite\"",
    "server": "node server.js",
    "client": "cd client && npx vite",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
